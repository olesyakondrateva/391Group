volatile long encoderCount = 0;

const int encoderA = 7;
const int encoderB = 8;

void setup() {

    Serial.begin(9600);

    pinMode(encoderA, INPUT_PULLUP);
    pinMode(encoderB, INPUT_PULLUP);

    // Full quadrature: interrupt on BOTH channels
    attachInterrupt(digitalPinToInterrupt(encoderA), updateEncoder, CHANGE);
    attachInterrupt(digitalPinToInterrupt(encoderB), updateEncoder, CHANGE);
}

void loop() {

    Serial.print("Encoder Count: ");
    Serial.println(encoderCount);

    delay(100);
}


// Full quadrature ISR (simple + reliable)
void updateEncoder() {

    static int lastA = 0;
    static int lastB = 0;

    int A = digitalRead(encoderA);
    int B = digitalRead(encoderB);

    // Determine direction using phase relationship
    if (A != lastA) {          // A changed
        if (A == B) encoderCount++;
        else encoderCount--;
    }
    else {                     // B changed
        if (A != B) encoderCount++;
        else encoderCount--;
    }

    lastA = A;
    lastB = B;
}
