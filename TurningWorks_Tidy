// =========================================================
// SETUP
// =========================================================

void setup() {

    pinMode(LED_BUILTIN, OUTPUT);


    // ---------------- BLE ----------------

    if (!BLE.begin()) {
        while (1);
    }

    BLE.setLocalName("BLE-DEVICE");
    BLE.setDeviceName("BLE-DEVICE");

    customService.addCharacteristic(customCharacteristic);

    BLE.addService(customService);

    customCharacteristic.writeValue("Waiting for data");

    BLE.advertise();


    // ---------------- Motors ----------------

    pinMode(A_IN1, OUTPUT);
    pinMode(A_IN2, OUTPUT);

    pinMode(B_IN1, OUTPUT);
    pinMode(B_IN2, OUTPUT);


    // ---------------- Encoders ----------------

    pinMode(encoderA1, INPUT_PULLUP);
    pinMode(encoderB1, INPUT_PULLUP);

    pinMode(encoderA2, INPUT_PULLUP);
    pinMode(encoderB2, INPUT_PULLUP);


    attachInterrupt(
        digitalPinToInterrupt(encoderA1),
        updateEncoder1,
        CHANGE
    );

    attachInterrupt(
        digitalPinToInterrupt(encoderB1),
        updateEncoder1,
        CHANGE
    );

    attachInterrupt(
        digitalPinToInterrupt(encoderA2),
        updateEncoder2,
        CHANGE
    );

    attachInterrupt(
        digitalPinToInterrupt(encoderB2),
        updateEncoder2,
        CHANGE
    );


    // ---------------- IMU ----------------

    Wire.setClock(400000);
    Wire1.setClock(400000);

    if (!IMU.begin()) {
        while (1);
    }
}


// =========================================================
// HELPER FUNCTIONS
// =========================================================


// Reset both encoder counts safely
void resetEncoders() {

    noInterrupts();

    encoderCount1 = 0;
    encoderCount2 = 0;

    count1 = 0;
    count2 = 0;

    interrupts();
}


// Read encoder counts safely
void updateEncoderSnapshot() {

    noInterrupts();
    count1 = encoderCount1;
    count2 = encoderCount2;
    interrupts();
}


// Convert encoder drift into a balancing offset
float getPositionOffset() {

    float posError = (count1 + count2) / 2.0;

    posError = constrain(posError, -100, 100);

    return 0.01 * posError;
}


// =========================================================
// MAIN LOOP
// =========================================================


void loop() {

    updateTilt();
    handleBLE();
    processCommand();
}


// =========================================================
// BLE FUNCTIONS
// =========================================================

void handleBLE() {

    BLEDevice central = BLE.central();

    if (central) {

        digitalWrite(LED_BUILTIN, HIGH);

        while (central.connected()) {

            updateTilt();

            readBLECommand();

            processCommand();
        }

        digitalWrite(LED_BUILTIN, LOW);
    }
}


void readBLECommand() {

    if (!customCharacteristic.written()) {
        return;
    }

    int length = customCharacteristic.valueLength();

    const unsigned char* receivedData =
        customCharacteristic.value();

    char receivedString[length + 1];

    memcpy(receivedString, receivedData, length);

    receivedString[length] = '\0';

    customCharacteristic.writeValue("Data received");

    strncpy(currentCommand, receivedString, BUFFER_SIZE);

    currentCommand[BUFFER_SIZE] = '\0';


    // Check if this is a new command
    if (strcmp(currentCommand, previousCommand) != 0) {

        firstCommandLoop = true;

        strncpy(
            previousCommand,
            currentCommand,
            BUFFER_SIZE
        );

        previousCommand[BUFFER_SIZE] = '\0';
    }
}


// =========================================================
// COMMAND HANDLER
// =========================================================

void processCommand() {

    // Reset encoder once when a new command arrives
    if (firstCommandLoop) {
        resetEncoders();
    }
    // ---------------- FORWARD ----------------

    if (strcmp(currentCommand, "FORWARD") == 0) {
        offset = 0.8;
        runBalanceAndTurn(offset);
    }

    // ---------------- REVERSE ----------------

    else if (strcmp(currentCommand, "REVERSE") == 0) {
        offset = -0.6;
        runBalanceAndTurn(offset);
    }

    // ---------------- LEFT ----------------

    else if (strcmp(currentCommand, "LEFT") == 0) {
        runBalanceAndTurn(0.5);
        switch(state) {
        case START:
            startTurn(45.0, 50);
            state = FIRST_TURN;
            break;

        case BLOCKING_BALANCE: 
            blockingBalance(3);
            startTurn(45.0, 50);
            state = SECOND_TURN;
        break;

        case FIRST_TURN:
            updateTurn();
            if (!turning) {
                //startTurn(45.0, 50);
                state = BLOCKING_BALANCE;
            }
            break;

        case SECOND_TURN:
            updateTurn();
            if (!turning) {
                state = FINISHED;
            }
            break;

        case FINISHED:
            runBalanceAndTurn(0.5);
            strcpy(currentCommand, "BALANCE");
            break;
         }
      }
    // ---------------- RIGHT ----------------

    else if (strcmp(currentCommand, "RIGHT") == 0) {
        runBalanceAndTurn(0.5);
        switch(state) {
        case START:
            //startTurn(-45.0, 50);
            state = FIRST_TURN;
            break;

        case BLOCKING_BALANCE: 
            blockingBalance(3);
            startTurn(-45.0, 50);
            state = SECOND_TURN;
        break;

        case FIRST_TURN:
            updateTurn();

            if (!turning) {
                state = BLOCKING_BALANCE;
            }
        break;

        case SECOND_TURN:
            updateTurn();
            if (!turning) {
                startTurn(-45.0, 50);
                state = FINISHED;
            }
        break;

        case FINISHED:
            //runBalanceAndTurn(0.5);
            strcpy(currentCommand, "BALANCE");
            break;
         }
    }

    // ---------------- STOP ----------------

    else if (strcmp(currentCommand, "STOP") == 0) {
        driveMotors(0,0);
    }
    // ---------------- BALANCE ----------------
    else if (strcmp(currentCommand, "BALANCE") == 0){
        offset = 0.5;
        runBalanceAndTurn(offset);
        state = START;
    }

    // Clear first loop flag
    firstCommandLoop = false;
}


