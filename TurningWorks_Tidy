// =========================================================
// IMU UPDATE
// =========================================================

void updateTilt() {

    float ax, ay, az;
    float gx, gy, gz;
    float accAngle;

    const float k = 0.99;


    if (IMU.accelerationAvailable() &&
        IMU.gyroscopeAvailable()) {

        unsigned long currentTime = micros();

        dt = (currentTime - prevTime) / 1000000.0;

        prevTime = currentTime;


        // Accelerometer angle
        IMU.readAcceleration(ax, ay, az);

        accAngle = atan2(ay, az) * 180 / PI;


        // Gyroscope
        IMU.readGyroscope(gx, gy, gz);

        gx_d = gx;


        if (firstRun) {

            gyroAngle =
                accAngle + (-gx) * dt;

            filterAngle =
                k * gyroAngle +
                (1 - k) * accAngle;

            firstRun = false;
        }

        else {

            gyroAngle =
                filterAngle + (-gx) * dt;

            filterAngle =
                k * gyroAngle +
                (1 - k) * accAngle;
        }
    }
}


// =========================================================
// BALANCE PID CONTROLLER
// =========================================================

float MotorController(float error, float dt) {

    float P = Kp * error;

    // Using gyro as derivative term
    float D = Kd * gx_d;

    // Integral term
    integral += error * dt;

    integral = constrain(integral, -150, 150);

    // Initial startup reset
    if (micros() < 5500000) {
        integral = 0;
    }


    // Setting integral to zero every 5 seconds 
    if (micros() > 10000000 && flag1) {
        integral = 0;
        flag1 = false;
    }

    if (micros() > 15000000 && flag2) {
        integral = 0;
        flag2 = false;
    }

    if (micros() > 20000000 && flag3) {
        integral = 0;
        flag3 = false;
    }

    if (micros() > 25000000 && flag4) {
        integral = 0;
        flag4 = false;
    }

    if (micros() > 30000000 && flag5) {
        integral = 0;
        flag5 = false;
    }

    if (micros() > 35000000 && flag6) {
        integral = 0;
        flag6 = false;
    }


    float I = Ki * integral;


    float PID = P + I + D;


    // Delay motor startup
    if (micros() < 5000000) {
        return 0;
    }

    return PID;
}


// =========================================================
// COMBINED BALANCE + TURN CONTROL
// =========================================================

void runBalanceAndTurn(float balanceOffset) {

    // Check whether the turn is finished
    updateTurn();
    // Get encoder position for drift correction
    updateEncoderSnapshot();
    float positionOffset = getPositionOffset();

    // Normal balancing output
    int balancePWM = (int)MotorController(
        desiredAngle
        - filterAngle
        + balanceOffset
        + positionOffset,
        dt
    );

    // Start with identical motor commands
    int leftPWM = balancePWM;
    int rightPWM = balancePWM;

    /*
     if (turning) {

        int turnCommand =
            turnDirection * turnPWM;


        leftPWM += turnCommand;
        rightPWM -= turnCommand;
    }
    */
   
   if (turning){
    long counts = (abs(encoderCount1) + abs(encoderCount2)) / 2;
    float turn_error = turnTarget - counts;
    // Scale from 1.0 (start) to 0.0 (finish)
    float scale = turn_error / turnTarget;
    // keep the motors from stalling near the end
    scale = constrain(scale, 0.3, 1.0);
    int turnCommand = turnDirection * turnPWM * scale;
    leftPWM += turnCommand;
    rightPWM -= turnCommand;
  }

  driveMotors(leftPWM, rightPWM);
}

// =========================================================
// MOTOR CONTROL 
// =========================================================

void driveMotors(int leftPWM, int rightPWM) {

    // Apply deadband compensation

    if (leftPWM > 10) {
        leftPWM += DEAD_A;
    }
    else if (leftPWM < -10) {
        leftPWM -= DEAD_A;
    }


    if (rightPWM > 10) {
        rightPWM += DEAD_B;
    }
    else if (rightPWM < -10) {
        rightPWM -= DEAD_B;
    }


    // Encoder-based yaw correction
    // Positive error means one wheel is ahead of the other
    if (!turning) {
    float yawError = count1 - count2;
    float K_yaw = 0.25;

    leftPWM -= K_yaw * yawError;
    rightPWM += K_yaw * yawError;
    }


    // Limit motor commands
    leftPWM = constrain(leftPWM, -MAX_PWM, MAX_PWM);
    rightPWM = constrain(rightPWM, -MAX_PWM, MAX_PWM);


    // ---------------- Motor A ----------------

    if (leftPWM > 0) {

        analogWrite(A_IN1, leftPWM);
        analogWrite(A_IN2, 0);

    }
    else if (leftPWM < 0) {

        analogWrite(A_IN1, 0);
        analogWrite(A_IN2, -leftPWM);

    }
    else {

        analogWrite(A_IN1, 0);
        analogWrite(A_IN2, 0);
    }


    // ---------------- Motor B ----------------

    if (rightPWM > 0) {

        analogWrite(B_IN1, rightPWM);
        analogWrite(B_IN2, 0);

    }
    else if (rightPWM < 0) {

        analogWrite(B_IN1, 0);
        analogWrite(B_IN2, -rightPWM);

    }
    else {

        analogWrite(B_IN1, 0);
        analogWrite(B_IN2, 0);
    }
}


// =========================================================
// ENCODER 1 INTERRUPT
// =========================================================

void updateEncoder1() {

    static int lastA = 0;

    int A = digitalRead(encoderA1);
    int B = digitalRead(encoderB1);


    if (A != lastA) {

        if (A == B) {
            encoderCount1++;
        }
        else {
            encoderCount1--;
        }

    }
    else {

        if (A != B) {
            encoderCount1++;
        }
        else {
            encoderCount1--;
        }
    }

    lastA = A;
}

// =========================================================
// ENCODER 2 INTERRUPT
// =========================================================

void updateEncoder2() {

    static int lastA = 0;

    int A = digitalRead(encoderA2);
    int B = digitalRead(encoderB2);


    if (A != lastA) {

        if (A == B) {
            encoderCount2++;
        }
    else {
            encoderCount2--;
        }

    }
    else {

        if (A != B) {
            encoderCount2++;
        }
        else {
            encoderCount2--;
        }
    }


    lastA = A;
}


